{
  "expo": {
    "name": "Club OS",
    "slug": "club-os",
    "version": "1.0.0",
    "scheme": "clubos",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syaan.clubos"
    },
    "android": {
      "package": "com.syaan.clubos",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3a6ff7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "36b467e0-4867-4cd9-b2fb-57d0e7b599a1"
      },
      "router": {}
    },
    "owner": "syaan.dev"
  }
}
