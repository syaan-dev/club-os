{
  "name": "club-os-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Tooling wrapper for the Club OS Supabase Edge Functions (Deno).",
  "scripts": {
    "serve": "supabase functions serve --no-verify-jwt",
    "deploy": "supabase functions deploy",
    "lint": "deno lint ../supabase/functions",
    "fmt": "deno fmt ../supabase/functions",
    "fmt:check": "deno fmt --check ../supabase/functions",
    "test": "deno test --allow-none ../supabase/functions/_shared",
    "check": "deno check ../supabase/functions/**/index.ts"
  },
  "engines": {
    "node": ">=18"
  }
}
