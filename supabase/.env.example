# Supabase local dev environment variables.
# Copy this file to `supabase/.env` (gitignored) and fill in real values.
# The CLI reads this automatically for `supabase start` / `supabase config push`.

# --- Twilio SMS provider (auth.sms.twilio) ---
# Found in the Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=twilio-account-sid
TWILIO_AUTH_TOKEN=twilio-auth-token
# Messaging Service SID (recommended) from Twilio > Messaging > Services.
TWILIO_MESSAGE_SERVICE_SID=twilio-message-service-sid
